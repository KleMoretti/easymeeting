<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easymeeting.mappers.MeetingFileRecordMapper">
    <resultMap id="base_result_map" type="com.easymeeting.entity.po.MeetingFileRecord">
        <id column="file_id" property="fileId"/>
        <result column="meeting_id" property="meetingId"/>
        <result column="upload_user_id" property="uploadUserId"/>
        <result column="file_name" property="fileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="file_type" property="fileType"/>
        <result column="file_suffix" property="fileSuffix"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.easymeeting.entity.po.MeetingFileRecord">
        INSERT INTO meeting_file_record(
            file_id,meeting_id,upload_user_id,file_name,file_path,file_size,file_type,file_suffix,create_time
        ) VALUES(
            #{bean.fileId},#{bean.meetingId},#{bean.uploadUserId},#{bean.fileName},#{bean.filePath},#{bean.fileSize},
            #{bean.fileType},#{bean.fileSuffix},#{bean.createTime}
        )
    </insert>

    <select id="selectByFileId" resultMap="base_result_map">
        SELECT
            file_id,meeting_id,upload_user_id,file_name,file_path,file_size,file_type,file_suffix,create_time
        FROM meeting_file_record
        WHERE file_id = #{fileId}
    </select>
</mapper>
